# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 100

# ------------------------
# Markdown files — keep trailing spaces for line breaks
# ------------------------
[*.md]
trim_trailing_whitespace = false
max_line_length = 100

# ------------------------
# YAML / JSON — always 2 spaces
# ------------------------
[*.{yml,yaml,json}]
indent_style = space
indent_size = 2

# ------------------------
# Makefile
# ------------------------
[Makefile]
indent_style = tab

# ------------------------
# Shell scripts
# ------------------------
[*.sh]
end_of_line = lf
